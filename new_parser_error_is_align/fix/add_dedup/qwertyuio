WITH CNT AS (
    SELECT businessdaydate, retailstoreid, transactiontypecode, workstationid, transactionsequencenumber, count(*) as qnty
    FROM ice_baby.core_flow_ing_raw.raw_bptransaction
    WHERE DATE(businessdaydate) = DATE '2026-03-21'
    GROUP BY businessdaydate, retailstoreid, transactiontypecode, workstationid, transactionsequencenumber
)
SELECT count(*) as duplicates FROM CNT WHERE qnty > 1

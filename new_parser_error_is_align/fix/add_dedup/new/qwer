WITH CNT AS (
    SELECT retailstoreid, businessdaydate, transactiontypecode, workstationid, transactionsequencenumber, count(*) as qnty
    FROM ice_baby.core_flow_ing_raw.raw_bptransaction
    WHERE DATE(businessdaydate) = DATE '2026-03-24'
    GROUP BY retailstoreid, businessdaydate, transactiontypecode, workstationid, transactionsequencenumber
)
SELECT qnty, count(*) as how_many
FROM CNT
WHERE qnty > 1
GROUP BY qnty
ORDER BY qnty

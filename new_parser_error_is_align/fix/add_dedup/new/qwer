WITH cnt AS (
    SELECT 
        retailstoreid, 
        businessdaydate, 
        workstationid, 
        transactionsequencenumber, 
        count(*) AS qnty
    FROM ice_baby.core_flow_ing_raw.raw_bptransaction_test
    GROUP BY retailstoreid, businessdaydate, workstationid, transactionsequencenumber
)
SELECT * FROM cnt
WHERE qnty > 1

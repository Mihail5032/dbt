SELECT tendersequencenumber, tendertypecode, tenderamount, COUNT(*)
FROM ice_baby.core_flow_ing_raw.raw_bptender
WHERE transactionsequencenumber = '100000000003489410'
  AND retailstoreid = '3934'
  AND businessdaydate = date '2026-03-15'
  AND load_ts_xml = TIMESTAMP '2026-03-21 00:12:34.641'
GROUP BY tendersequencenumber, tendertypecode, tenderamount;
